    "catalog:refresh": "npm run import:products && npm run tag:products && npm test",
    "coverage:report": "node scripts/coverage-report.js",
    "coverage:report:llm": "ENABLE_LLM_FALLBACK=1 node scripts/coverage-report.js",
    "tag:coverage:audit": "node scripts/tag-coverage-audit.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "axios": "^1.13.6",
    "cors": "^2.8.6",
    "csv-parser": "^3.2.0",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.2"
  },
  "devDependencies": {
    "jest": "^30.3.0",
    "supertest": "^7.2.2"
  },
  "jest": {
    "testPathIgnorePatterns": [
      "/node_modules/",
      "<rootDir>/frontend/"
