{
  "version": 1,
  "title": "Top 25 prompts regression suite (Notion: Deliverable Top 25 prompts)",
  "reference": "https://www.notion.so/248e2badf3af42e9b3f2ff48d1b26f17",
  "rubricLegend": {
    "actionAnyOf": "Last turn decision.action must be one of listed values",
    "actionMustBe": "Exact decision.action",
    "missingSlotAnyOf": "decision.missingSlot must be one of (null uses explicit null in list)",
    "flowIdAnyOf": "decision.flowId must be one of",
    "forbidActionAnyOf": "decision.action must NOT be any of these",
    "outputTypeAnyOf": "output.type must be one of",
    "productsReasonAnyOf": "decision.productsReason or output.productsReason",
    "sessionSlots": "After last turn, session.slots checks (objectNot, contextAnyOf, etc.)"
  },
