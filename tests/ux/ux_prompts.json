      "expect": {
        "noEnglish": true,
        "noGenericClarification": true,
        "noEmptyReply": true,
        "noRepeatedQuestion": true
      }
    },
    {
      "id": "ux-04",
      "title": "Follow-up nu intra in bucla",
      "steps": [
        "Vreau sa curat bordul.",
        "Bugetul meu este 80 lei."
      ],
      "expect": {
        "noEnglish": true,
        "noGenericClarification": true,
        "noEmptyReply": true,
        "noRepeatedQuestion": true
      }
