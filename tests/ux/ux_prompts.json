{
  "suite": "ux-regression-week1",
  "version": 1,
  "cases": [
    {
      "id": "ux-01",
      "title": "Clarificare ghidata pentru obiect lipsa",
      "steps": ["Vreau ceva pentru masina mea."],
      "expect": {
        "noEnglish": true,
        "noGenericClarification": true,
        "noEmptyReply": true,
        "noRepeatedQuestion": true
      }
    },
    {
      "id": "ux-02",
      "title": "Clarificare ghidata pentru buget",
      "steps": ["Am nevoie de o solutie de detailing exterior."],
      "expect": {
        "noEnglish": true,
        "noGenericClarification": true,
        "noEmptyReply": true,
        "noRepeatedQuestion": true
      }
    },
    {
      "id": "ux-03",
